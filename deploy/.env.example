# Copy to deploy/.env and fill in real values. Never commit the real .env.
#
# These variables are consumed directly by docker-compose.yml, which then
# assembles DATABASE_URL / REDIS_URL for the api container. For local
# (non-Docker) backend dev, set DATABASE_URL / REDIS_URL directly in
# backend/.env instead — see backend/app/core/config.py.

# --- Caddy ---
# Real domain enables Caddy's automatic HTTPS; "localhost" (default) does not.
DOMAIN=localhost

# --- API instance config (spec §6b: 12-factor, no code branches beyond these) ---
ENV=production
INSTANCE_MODE=self_hosted
ALLOW_SIGNUP=false
# Generate with: openssl rand -hex 32
SESSION_SECRET=changeme-generate-a-real-secret

# --- Postgres ---
POSTGRES_USER=tally
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tally

# --- Redis ---
REDIS_PASSWORD=changeme
