# syntax=docker/dockerfile:1
# Build context is the repo root (see docker-compose.yml) so this stage can pull
# in frontend/ and the Caddyfile lives alongside it in deploy/.
FROM node:25-slim AS frontend-build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ .
RUN npm run build

FROM caddy:2-alpine
COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=frontend-build /app/dist /srv
