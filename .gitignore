# Env / secrets
.env
.env.*
.env.local
.env.*.local
!.env.example
*.pem
*.key

# Claude Code local config (may contain project-local settings/credentials).
# Project skills (.claude/skills/) are shared, versioned tooling -- not local
# config -- so they're explicitly un-ignored below.
.claude/*
!.claude/skills

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Node / frontend
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# Docker
*.override.yml

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Backups (never commit real dumps)
*.dump
*.sql.gz
*.age

# Generated by the run-tally skill's driver -- not part of the skill itself
.claude/skills/run-tally/screenshots/
